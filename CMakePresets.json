{
  "version": 5,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "_base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/build/install/${presetName}",
      "cacheVariables": {
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
      }
    },
    {
      "name": "_vcpkg",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": {
          "type": "FILEPATH",
          "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      },
      "condition": {
        "type": "notEquals",
        "lhs": "$env{VCPKG_ROOT}",
        "rhs": ""
      }
    },
    {
      "name": "default",
      "displayName": "Visual Studio 2026 (x64)",
      "description": "Default preset: VS 2026, x64, uses VCPKG_ROOT if available.",
      "inherits": ["_base", "_vcpkg"],
      "generator": "Visual Studio 18 2026",
      "architecture": "x64"
    },
    {
      "name": "ninja",
      "displayName": "Ninja (cl.exe, x64)",
      "description": "Single-config Ninja build using MSVC. Run from an x64 Developer Command Prompt.",
      "inherits": ["_base", "_vcpkg"],
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug",          "configurePreset": "default", "configuration": "Debug" },
    { "name": "release",        "configurePreset": "default", "configuration": "Release" },
    { "name": "relwithdebinfo", "configurePreset": "default", "configuration": "RelWithDebInfo" },
    { "name": "ninja-release",  "configurePreset": "ninja" }
  ]
}
